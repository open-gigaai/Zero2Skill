# Copy to configs/paths.env and fill in for YOUR robot / cameras.
# Reference lab setup used Agilex Piper arms + Intel RealSense cameras; nothing
# here is hard-required to be Piper or RealSense.

# ZERO2SKILL_ROOT=/path/to/Zero2Skill

# --- Conda ---
CONDA_SH="${CONDA_SH:-$HOME/miniconda3/etc/profile.d/conda.sh}"
# Single project env for capture, IK/motion, collect stats/video.
CONDA_ENV="${CONDA_ENV:-zero2skill}"
# Install AnyGrasp / SAM3 with their official instructions, then set the env names here.
CONDA_ENV_SAM3="${CONDA_ENV_SAM3:-}"          # e.g. the env name from the SAM3 docs
CONDA_ENV_ANYGRASP="${CONDA_ENV_ANYGRASP:-}"  # e.g. the env name from the AnyGrasp docs

# --- ROS ---
ROS_SETUP="${ROS_SETUP:-/opt/ros/noetic/setup.bash}"
# Optional workspace overlays / launch files for your arm and cameras.
ARM_ROS_SETUP="${ARM_ROS_SETUP:-}"
CAMERA_ROS_SETUP="${CAMERA_ROS_SETUP:-}"
CAMERA_LAUNCH="${CAMERA_LAUNCH:-}"   # e.g. "pkg_name your_camera.launch"

# Optional arm launch for skills/grasp-tool/scripts/start_robot_infra.sh
ARM_LAUNCH="${ARM_LAUNCH:-}"
ARM_PRESTART_SH="${ARM_PRESTART_SH:-}"

# --- Arm IK / URDF (piper_pose_ik.py adapter; point at YOUR Pinocchio/URDF tree) ---
ARM_ROS_SRC="${ARM_ROS_SRC:-}"
ARM_IK_DIR="${ARM_IK_DIR:-}"
ARM_URDF="${ARM_URDF:-}"

# --- External HDF5 recorder (not vendored) ---
COLLECT_RECORDER_PY="${COLLECT_RECORDER_PY:-}"

# --- SAM3 checkpoint (if using text-prompt segmentation) ---
SAM3_CHECKPOINT="${SAM3_CHECKPOINT:-}"

# --- AnyGrasp runtime ---
GSNET_DIR="${GSNET_DIR:-}"
ANYGRASP_CHECKPOINT="${ANYGRASP_CHECKPOINT:-}"

# --- ROS topics (match your drivers) ---
TOPIC_FRONT_COLOR="${TOPIC_FRONT_COLOR:-/camera_f/color/image_raw}"
TOPIC_FRONT_DEPTH="${TOPIC_FRONT_DEPTH:-/camera_f/depth/image_raw}"
TOPIC_LEFT_COLOR="${TOPIC_LEFT_COLOR:-/camera_l/color/image_raw}"
TOPIC_RIGHT_COLOR="${TOPIC_RIGHT_COLOR:-/camera_r/color/image_raw}"
TOPIC_JOINT_LEFT="${TOPIC_JOINT_LEFT:-/puppet/joint_left}"
TOPIC_JOINT_RIGHT="${TOPIC_JOINT_RIGHT:-/puppet/joint_right}"

# --- Front camera intrinsics (pixels) + depth scale ---
# Leave empty until calibrated; grasp code requires these for point-cloud projection.
CAM_FX="${CAM_FX:-}"
CAM_FY="${CAM_FY:-}"
CAM_CX="${CAM_CX:-}"
CAM_CY="${CAM_CY:-}"
DEPTH_SCALE="${DEPTH_SCALE:-1000.0}"

# Optional: cam-to-base extrinsics JSON (see camera_extrinsics.example.json)
# CAMERA_EXTRINSICS_JSON="$ZERO2SKILL_ROOT/configs/camera_extrinsics.json"

# --- VLM (success judging / three-view) ---
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=
